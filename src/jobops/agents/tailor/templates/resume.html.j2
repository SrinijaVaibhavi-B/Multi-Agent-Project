<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: "Arial", "Helvetica Neue", sans-serif;
    font-size: 9pt;
    color: #1a1a2e;
    background: white;
    padding: 0.1in;
    line-height: 1.3;
  }

  /* ── Header ── */
  .header {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
    color: white;
    padding: 10px 14px 8px 14px;
    margin-bottom: 7px;
    border-radius: 3px;
  }
  .name {
    font-size: 18pt;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #ffffff;
  }
  .tagline {
    font-size: 8.5pt;
    color: #e0d7f5;
    margin-top: 1px;
    margin-bottom: 5px;
    font-style: italic;
  }
  .contact {
    font-size: 8pt;
    color: #c8c0e8;
    margin-top: 3px;
  }
  .contact a { color: #a8d8ea; text-decoration: none; }
  .contact .pipe { margin: 0 5px; color: #6655a0; }

  /* ── Section titles ── */
  .section-title {
    font-size: 8.5pt;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.4px;
    color: #0f3460;
    border-bottom: 2px solid #e94560;
    margin-top: 7px;
    margin-bottom: 3px;
    padding-bottom: 1px;
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .section-title::before {
    content: "";
    display: inline-block;
    width: 6px;
    height: 6px;
    background: #e94560;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── Summary ── */
  .summary {
    font-size: 8.5pt;
    line-height: 1.45;
    color: #2d2d44;
    background: #f8f7ff;
    border-left: 3px solid #e94560;
    padding: 4px 7px;
    border-radius: 0 2px 2px 0;
  }

  /* ── Experience ── */
  .job { margin-bottom: 5px; }
  .job-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .job-company {
    font-weight: 700;
    font-size: 9.5pt;
    color: #0f3460;
  }
  .job-location { font-size: 8pt; color: #666; }
  .job-mid {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2px;
  }
  .job-title { font-style: italic; font-size: 8.5pt; color: #444; }
  .job-dates {
    font-size: 8pt;
    color: white;
    background: #0f3460;
    padding: 1px 6px;
    border-radius: 8px;
    font-weight: 600;
    white-space: nowrap;
  }
  .job-contract { font-size: 7.5pt; color: #888; font-style: italic; margin-bottom: 2px; }

  ul { padding-left: 11px; }
  li {
    margin-bottom: 1.5px;
    font-size: 8.5pt;
    line-height: 1.35;
    color: #2d2d44;
  }
  li strong {
    font-weight: 700;
    color: #0f3460;
  }

  /* ── Skills ── */
  .skills-grid { width: 100%; border-collapse: collapse; }
  .skill-label {
    font-weight: 700;
    font-size: 8pt;
    white-space: nowrap;
    padding: 1px 6px 1px 0;
    width: 100px;
    vertical-align: top;
    color: #e94560;
  }
  .skill-value {
    font-size: 8pt;
    color: #2d2d44;
    padding: 1px 0;
    border-bottom: 1px dotted #e8e8f0;
  }

  /* ── Education ── */
  .edu-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .edu-school { font-weight: 700; font-size: 9.5pt; color: #0f3460; }
  .edu-location { font-size: 8pt; color: #666; }
  .edu-mid {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1px;
  }
  .edu-degree { font-style: italic; font-size: 8.5pt; color: #444; }
  .edu-dates {
    font-size: 8pt;
    color: white;
    background: #0f3460;
    padding: 1px 6px;
    border-radius: 8px;
    font-weight: 600;
  }

  /* ── Projects ── */
  .project-name { font-weight: 700; font-size: 9pt; color: #0f3460; }
  .project-stack { font-size: 8pt; color: #e94560; font-style: italic; }

  /* ── Certifications ── */
  .cert-list {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 2px;
  }
  .cert-badge {
    font-size: 7.5pt;
    background: #f0f4ff;
    border: 1px solid #0f3460;
    color: #0f3460;
    padding: 2px 7px;
    border-radius: 10px;
    font-weight: 600;
  }
</style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <div class="name">{{ name }}</div>
  <div class="tagline">Software Engineer &nbsp;·&nbsp; AI &amp; Agentic Systems &nbsp;·&nbsp; Full-Stack &nbsp;·&nbsp; Cloud</div>
  <div class="contact">
    <a href="mailto:{{ email }}">{{ email }}</a>
    <span class="pipe">|</span>{{ phone }}
    <span class="pipe">|</span><a href="{{ github }}">{{ github | replace("https://github.com/", "github.com/") }}</a>
    <span class="pipe">|</span><a href="{{ linkedin }}">{{ linkedin | replace("https://www.linkedin.com/in/", "linkedin.com/in/") }}</a>
  </div>
</div>

<!-- SUMMARY -->
{% if summary %}
<div class="section-title">Summary</div>
<div class="summary">{{ summary }}</div>
{% endif %}

<!-- SKILLS -->
<div class="section-title">Skills</div>
<table class="skills-grid">
{% for label, items in skills.items() %}
<tr>
  <td class="skill-label">{{ label }}</td>
  <td class="skill-value">{{ items | join(", ") }}</td>
</tr>
{% endfor %}
</table>

<!-- EXPERIENCE -->
<div class="section-title">Experience</div>
{% for job in experience %}
<div class="job">
  <div class="job-top">
    <span class="job-company">{{ job.company }}</span>
    <span class="job-location">{{ job.location }}</span>
  </div>
  <div class="job-mid">
    <span class="job-title">{{ job.title }}</span>
    <span class="job-dates">{{ job.dates }}</span>
  </div>
  {% if job.contract_notes is defined and job.contract_notes %}
  <div class="job-contract">{{ job.contract_notes }}</div>
  {% endif %}
  <ul>
  {% for bullet in job.bullets %}
    <li>{{ bullet }}</li>
  {% endfor %}
  </ul>
</div>
{% endfor %}

<!-- VOLUNTEER -->
{% if volunteer %}
<div class="section-title">Volunteer</div>
{% for v in volunteer %}
<div class="job">
  <div class="job-top">
    <span class="job-company">{{ v.org }}</span>
    <span class="job-location">{{ v.location }}</span>
  </div>
  <div class="job-mid">
    <span class="job-title">{{ v.title }}</span>
    <span class="job-dates">{{ v.dates }}</span>
  </div>
  <ul>
  {% for bullet in v.bullets %}
    <li>{{ bullet }}</li>
  {% endfor %}
  </ul>
</div>
{% endfor %}
{% endif %}

<!-- EDUCATION -->
<div class="section-title">Education</div>
{% for edu in education %}
<div class="edu-top">
  <span class="edu-school">{{ edu.school }}</span>
  <span class="edu-location">{{ edu.location }}</span>
</div>
<div class="edu-mid">
  <span class="edu-degree">{{ edu.degree }}{% if edu.gpa %} &nbsp;·&nbsp; GPA: {{ edu.gpa }}{% endif %}</span>
  <span class="edu-dates">{{ edu.dates }}</span>
</div>
{% if edu.notes %}
<ul style="margin-top:2px;">
{% for note in edu.notes %}
  <li>{{ note }}</li>
{% endfor %}
</ul>
{% endif %}
{% endfor %}

<!-- PROJECTS -->
{% if projects %}
<div class="section-title">Projects</div>
{% for proj in projects %}
<div style="margin-bottom:4px;">
  <span class="project-name">{{ proj.name }}</span>
  {% if proj.stack %}<span class="project-stack"> &nbsp;|&nbsp; {{ proj.stack }}</span>{% endif %}
  <ul style="margin-top:1px;">
  {% for bullet in proj.bullets %}
    <li>{{ bullet }}</li>
  {% endfor %}
  </ul>
</div>
{% endfor %}
{% endif %}

<!-- CERTIFICATIONS -->
{% if certifications %}
<div class="section-title">Certifications</div>
<div class="cert-list">
{% for cert in certifications %}
  <span class="cert-badge">{{ cert }}</span>
{% endfor %}
</div>
{% endif %}

</body>
</html>
