<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<style>
  @page { margin: 4px; }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: "Calibri", "Trebuchet MS", "Arial", sans-serif;
    font-size: 9pt;
    color: #1f2937;
    background: #ffffff;
    padding: 4px 6px;
    line-height: 1.3;
  }

  /* ── Header ── */
  .header {
    background: #0f172a;
    padding: 10px 14px 9px;
    margin-bottom: 6px;
    border-radius: 2px;
  }
  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }
  .name {
    font-size: 20pt;
    font-weight: 700;
    color: #f8fafc;
    letter-spacing: 1.5px;
    line-height: 1;
    text-transform: uppercase;
  }
  .name-sub {
    font-size: 8pt;
    color: #38bdf8;
    letter-spacing: 1px;
    margin-top: 3px;
    text-transform: uppercase;
    font-weight: 600;
  }
  .contact-block {
    text-align: right;
    font-size: 7.5pt;
    color: #94a3b8;
    line-height: 1.6;
  }
  .contact-block a { color: #7dd3fc; text-decoration: none; }

  /* ── Section titles ── */
  .section-title {
    font-size: 8pt;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.6px;
    color: #0369a1;
    border-bottom: 1.5px solid #0369a1;
    margin-top: 7px;
    margin-bottom: 3px;
    padding-bottom: 1px;
  }

  /* ── Summary ── */
  .summary {
    font-size: 8.5pt;
    line-height: 1.45;
    color: #374151;
    padding: 3px 0;
  }

  /* ── Experience ── */
  .job { margin-bottom: 5px; }

  .job-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0px;
  }
  .job-company {
    font-weight: 700;
    font-size: 9.5pt;
    color: #0f172a;
  }
  .job-right {
    text-align: right;
  }
  .job-dates {
    font-size: 7.5pt;
    font-weight: 700;
    color: #0369a1;
    background: #e0f2fe;
    padding: 1px 7px;
    border-radius: 10px;
  }
  .job-sub {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2px;
  }
  .job-title {
    font-style: italic;
    font-size: 8.5pt;
    color: #4b5563;
  }
  .job-location {
    font-size: 7.5pt;
    color: #9ca3af;
  }
  .job-contract {
    font-size: 7.5pt;
    color: #9ca3af;
    font-style: italic;
    margin-bottom: 2px;
  }

  ul { padding-left: 11px; }
  li {
    margin-bottom: 2px;
    font-size: 8.5pt;
    line-height: 1.35;
    color: #374151;
  }
  li strong {
    font-weight: 700;
    color: #0f172a;
  }

  /* ── Skills ── */
  .skills-table { width: 100%; border-collapse: collapse; }
  .skill-label {
    font-weight: 700;
    font-size: 7.5pt;
    color: #0369a1;
    width: 92px;
    vertical-align: top;
    padding: 1px 5px 1px 0;
    white-space: nowrap;
  }
  .skill-value {
    font-size: 8pt;
    color: #374151;
    padding: 1px 0;
    border-bottom: 1px solid #f1f5f9;
  }

  /* ── Education ── */
  .edu-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .edu-school { font-weight: 700; font-size: 9.5pt; color: #0f172a; }
  .edu-sub {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1px;
  }
  .edu-degree { font-style: italic; font-size: 8.5pt; color: #4b5563; }
  .edu-dates {
    font-size: 7.5pt;
    font-weight: 700;
    color: #0369a1;
    background: #e0f2fe;
    padding: 1px 7px;
    border-radius: 10px;
  }
  .edu-location { font-size: 7.5pt; color: #9ca3af; }

  /* ── Projects ── */
  .proj-header { margin-bottom: 1px; }
  .project-name { font-weight: 700; font-size: 9pt; color: #0f172a; }
  .project-stack { font-size: 8pt; color: #0369a1; font-style: italic; }

  /* ── Certifications ── */
  .cert-list { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 2px; }
  .cert-badge {
    font-size: 7.5pt;
    border: 1px solid #0369a1;
    color: #0369a1;
    padding: 2px 8px;
    border-radius: 12px;
    font-weight: 600;
    background: #f0f9ff;
  }
</style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <div class="header-inner">
    <div>
      <div class="name">{{ name }}</div>
      <div class="name-sub">Software Engineer &nbsp;·&nbsp; AI &amp; Agentic Systems &nbsp;·&nbsp; Full-Stack &nbsp;·&nbsp; Cloud</div>
    </div>
    <div class="contact-block">
      <a href="mailto:{{ email }}">{{ email }}</a><br>
      {{ phone }}<br>
      <a href="{{ github }}">{{ github | replace("https://github.com/", "github.com/") }}</a><br>
      <a href="{{ linkedin }}">{{ linkedin | replace("https://www.linkedin.com/in/", "linkedin.com/in/") }}</a>
    </div>
  </div>
</div>

<!-- SUMMARY -->
{% if summary %}
<div class="section-title">Summary</div>
<div class="summary">{{ summary }}</div>
{% endif %}

<!-- SKILLS -->
<div class="section-title">Skills</div>
<table class="skills-table">
{% for label, items in skills.items() %}
<tr>
  <td class="skill-label">{{ label }}</td>
  <td class="skill-value">{{ items | join(", ") }}</td>
</tr>
{% endfor %}
</table>

<!-- EXPERIENCE -->
<div class="section-title">Experience</div>
{% for job in experience %}
<div class="job">
  <div class="job-header">
    <span class="job-company">{{ job.company }}</span>
    <span class="job-dates">{{ job.dates }}</span>
  </div>
  <div class="job-sub">
    <span class="job-title">{{ job.title }}</span>
    <span class="job-location">{{ job.location }}</span>
  </div>
  {% if job.contract_notes is defined and job.contract_notes %}
  <div class="job-contract">{{ job.contract_notes }}</div>
  {% endif %}
  <ul>
  {% for bullet in job.bullets %}
    <li>{{ bullet }}</li>
  {% endfor %}
  </ul>
</div>
{% endfor %}

<!-- VOLUNTEER -->
{% if volunteer %}
<div class="section-title">Volunteer</div>
{% for v in volunteer %}
<div class="job">
  <div class="job-header">
    <span class="job-company">{{ v.org }}</span>
    <span class="job-dates">{{ v.dates }}</span>
  </div>
  <div class="job-sub">
    <span class="job-title">{{ v.title }}</span>
    <span class="job-location">{{ v.location }}</span>
  </div>
  <ul>
  {% for bullet in v.bullets %}
    <li>{{ bullet }}</li>
  {% endfor %}
  </ul>
</div>
{% endfor %}
{% endif %}

<!-- EDUCATION -->
<div class="section-title">Education</div>
{% for edu in education %}
<div style="margin-bottom:3px;">
  <div class="edu-header">
    <span class="edu-school">{{ edu.school }}</span>
    <span class="edu-location">{{ edu.location }}</span>
  </div>
  <div class="edu-sub">
    <span class="edu-degree">{{ edu.degree }}{% if edu.gpa %} &nbsp;·&nbsp; GPA: {{ edu.gpa }}{% endif %}</span>
    <span class="edu-dates">{{ edu.dates }}</span>
  </div>
  {% if edu.notes %}
  <ul style="margin-top:1px;">
  {% for note in edu.notes %}<li>{{ note }}</li>{% endfor %}
  </ul>
  {% endif %}
</div>
{% endfor %}

<!-- PROJECTS -->
{% if projects %}
<div class="section-title">Projects</div>
{% for proj in projects %}
<div class="proj-header">
  <span class="project-name">{{ proj.name }}</span>
  {% if proj.stack %}<span class="project-stack"> &nbsp;|&nbsp; {{ proj.stack }}</span>{% endif %}
</div>
<ul style="margin-bottom:4px;">
{% for bullet in proj.bullets %}<li>{{ bullet }}</li>{% endfor %}
</ul>
{% endfor %}
{% endif %}

<!-- CERTIFICATIONS -->
{% if certifications %}
<div class="section-title">Certifications</div>
<div class="cert-list">
{% for cert in certifications %}
  <span class="cert-badge">{{ cert.name if cert is mapping else cert }}</span>
{% endfor %}
</div>
{% endif %}

<!-- WORK AUTHORIZATION -->
{% if work_authorization %}
<div style="margin-top:6px; font-size:7.5pt; color:#6b7280; border-top:1px solid #e5e7eb; padding-top:4px;">
  <strong style="color:#374151;">Work Authorization:</strong> {{ work_authorization }}
</div>
{% endif %}

</body>
</html>
